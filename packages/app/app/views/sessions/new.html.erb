<% content_for :title, "Sign in — FaleCom" %>

<div class="mx-auto flex min-h-[80vh] max-w-sm flex-col justify-center">
  <h1 class="mb-6 text-2xl font-semibold tracking-tight">Sign in to FaleCom</h1>

  <% if alert = flash[:alert] %>
    <div role="alert" class="mb-4 rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-800 dark:border-red-900 dark:bg-red-950 dark:text-red-200">
      <%= alert %>
    </div>
  <% end %>

  <%= form_with url: session_path, class: "space-y-4" do |f| %>
    <%= f.jr_text_field :email_address,
          label: "Email",
          required: true,
          autofocus: true,
          autocomplete: "email" %>

    <%= f.jr_password_field :password,
          label: "Password",
          required: true,
          autocomplete: "current-password" %>

    <%= render Ui::ButtonComponent.new(
      label: "Sign in",
      type: "submit",
      variant: "primary",
      class: "w-full"
    ) %>
  <% end %>

  <p class="mt-6 text-center text-sm text-slate-500 dark:text-slate-400">
    <%= link_to "Forgot password?", new_password_path, class: "underline" %>
  </p>
</div>
