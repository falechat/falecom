<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title><%= content_for(:title) || "FaleCom" %></title>

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= vite_client_tag %>
    <%= vite_javascript_tag "application" %>
    <%= vite_stylesheet_tag "application" %>
  </head>

  <body class="h-full bg-white text-slate-900 antialiased dark:bg-slate-950 dark:text-slate-100">
    <div class="flex min-h-full">
      <% if authenticated? %>
        <%= render Ui::SidebarComponent.new(
          items: [
            { label: "Dashboard", href: root_path, icon: "home" }
          ]
        ) %>
      <% end %>

      <div class="flex min-w-0 flex-1 flex-col">
        <%= render Ui::NavbarComponent.new(
          brand: "FaleCom",
          user: Current.user
        ) %>

        <main class="flex-1 px-6 py-8">
          <%= yield %>
        </main>
      </div>
    </div>
  </body>
</html>
