<header class="flex items-center justify-between border-b border-slate-200 bg-white px-6 py-3 dark:border-slate-700 dark:bg-slate-900">
  <span class="text-lg font-semibold tracking-tight text-slate-900 dark:text-slate-100"><%= @brand %></span>
  <% if @user %>
    <span class="text-sm text-slate-500 dark:text-slate-400"><%= @user.email_address %></span>
  <% end %>
</header>
